PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Catalog source for backend endpoint /api/products?provider=amazon
AMAZON_API_BASE_URL=
AMAZON_PRODUCTS_PATH=/products
AMAZON_ACCESS_TOKEN=
AMAZON_API_KEY=

# If amazon upstream fails, return local mock products instead of 500
AMAZON_FALLBACK_TO_MOCK=true

# If freeapi upstream fails, return local mock products instead of 500
FREEAPI_FALLBACK_TO_MOCK=true

# Omkar Amazon scraper API
OMKAR_API_KEY=
OMKAR_COUNTRY_CODE=IN
OMKAR_DEFAULT_QUERY=best sellers
OMKAR_FALLBACK_TO_FREEAPI=true
OMKAR_MAX_PAGES=50
OMKAR_CACHE_TTL_MS=180000
