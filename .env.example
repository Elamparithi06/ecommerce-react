VITE_PRODUCT_PROVIDER=backend
VITE_API_BASE_URL=http://localhost:4000
VITE_BACKEND_CATALOG_PROVIDER=freeapi
VITE_BACKEND_CATALOG_LIMIT=5000
# Supported values:
# VITE_PRODUCT_PROVIDER:
# backend   -> use Express API from this project (recommended)
# mock      -> local product catalog in frontend only
# fakestore -> public demo API (for testing only)
#
# VITE_BACKEND_CATALOG_PROVIDER:
# freeapi   -> free public APIs (DummyJSON + JSONPlaceholder reviews)
# omkar     -> omkar.cloud Amazon scraper provider (requires server OMKAR_API_KEY)
# mock      -> backend serves local mock catalog
# amazon    -> backend tries Amazon upstream integration and falls back to mock by default
